@inject IJSRuntime JSRuntime

<svg xmlns="http://www.w3.org/2000/svg"
    width=@Width
    height=@Height
    viewBox=@ViewBox
    @ref="SvgRef"
    class="@ClassName"
     @onclick="OnClick">
    <path d=@Path />
</svg>

@code {
    [Parameter]
    public string Path { get; set; } = Paths.QuestionMark;

    [Parameter]
    public int Width { get; set; } = 20;

    [Parameter]
    public int Height { get; set; } = 20;

    [Parameter]
    public string? ClassName { get; set; }

    [Parameter]
    public EventCallback OnClick { get; set; }

    private string ViewBox { get; set; } = "0 0 960 960"; // Default viewBox
    private ElementReference SvgRef;
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                // Pass SvgRef to the JavaScript function
                var viewBoxData = await JSRuntime.InvokeAsync<string>(
                    "getSvgViewBox",
                    new object[] { SvgRef }
                 );

                if (!string.IsNullOrEmpty(viewBoxData))
                {
                    ViewBox = viewBoxData;
                    StateHasChanged();
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error computing viewBox: {ex.Message}");
            }
        }
    }

