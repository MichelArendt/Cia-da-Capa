                    "getSvgViewBox",
                    new object[] { SvgRef }
                 );

                if (!string.IsNullOrEmpty(viewBoxData))
                {
                    ViewBox = viewBoxData;
                    StateHasChanged();
                }
            }
            catch (Exception ex)
            {
