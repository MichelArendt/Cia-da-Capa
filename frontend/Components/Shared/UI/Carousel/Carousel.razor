@code {
    [Parameter] public List<CarouselItem> Items { get; set; } = new();
    [Parameter] public bool AutoScroll { get; set; } = false;
    [Parameter] public PaginationType Pagination { get; set; } = PaginationType.NONE;
    [Parameter] public bool PaginationArrows { get; set; } = false;
    [Parameter] public bool ItemsAlwaysCentered { get; set; } = false;

    [Parameter] public int MaxWidth { get; set; } = 0;
    [Parameter] public int MaxHeight { get; set; } = 0;

    [Inject] private IJSRuntime JSRuntime { get; set; } = default!;
    private DotNetObjectReference<Carousel>? _dotNetHelper;
    private ElementReference CarouselContentRef;
    private ElementReference CarouselPaginationRef;
    private int _currentIndex = 0;
    private System.Timers.Timer? _scrollTimer;

    [JSInvokable]
    public int GetCurrentIndex() => _currentIndex;

    protected override void OnInitialized()
    {
        AppStateService.IsMobileChanged += StateHasChanged;
        base.OnInitialized();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        // Create the .NET reference only once.
        // JS uses this to call instance methods back in Blazor.
        if (_dotNetHelper is null)
            _dotNetHelper = DotNetObjectReference.Create(this);
            
        // Attach swipe behavior.
        // After improvement C, we will no longer pass _currentIndex here.
        await JSRuntime.InvokeVoidAsync(
            "enableDirectionalSwipeScroll",
            CarouselContentRef,
            _dotNetHelper,
            Items.Count
        );

        // Initialize carousel position on first render
        if (firstRender)
        {
            // Wait for stable layout and then place the first item correctly.
            await JSRuntime.InvokeVoidAsync(
                "initializeCarouselPosition",
                CarouselContentRef,
                CarouselPaginationRef,
                0,
                ItemsAlwaysCentered
            );
            
            // Keep the active state synchronized with the initialized position.
            _currentIndex = 0;
            StateHasChanged();

            // Observe future size/layout changes and re-center the active item when needed.
            await JSRuntime.InvokeVoidAsync(
                "attachCarouselResizeObserver",
                CarouselContentRef,
                CarouselPaginationRef,
                _dotNetHelper,
                ItemsAlwaysCentered
            );
        }


        // Set up auto-scroll timer if enabled
        if (firstRender && AutoScroll)
        {
            _scrollTimer?.Dispose();

            _scrollTimer = new System.Timers.Timer(3000); // scroll every 3 seconds
            _scrollTimer.Elapsed += async (_, _) =>
            {
                await InvokeAsync(async () =>
                {
                    var nextIndex = (_currentIndex + 1) % Items.Count;
                    await ScrollToIndex(nextIndex);
                });
            };
            _scrollTimer.AutoReset = true;
            _scrollTimer.Start();
        }
    }

    [JSInvokable]
    public void UpdateCurrentIndex(int index)
    {
        if (_currentIndex != index)
        {
            _currentIndex = index;
            StateHasChanged();
        }
    }

    [JSInvokable]
    public async Task ScrollToIndex(int index)
    {
        _currentIndex = index;
        StateHasChanged(); // update the active class in both lists

        await JSRuntime.InvokeVoidAsync(
            "scrollCarouselToIndex",
            CarouselContentRef,
            CarouselPaginationRef,
            index,
            ItemsAlwaysCentered
        );

        ResetAutoScrollTimer(); // stop/start the timer!
    }

    private void ResetAutoScrollTimer()
    {
        if (AutoScroll && _scrollTimer != null)
        {
            _scrollTimer.Stop();
            _scrollTimer.Start();
        }
    }

    private string CarouselStyle
    {
        get
        {
            var styles = new List<string>();
            if (MaxWidth > 0)
                styles.Add($"max-width: {MaxWidth}px");
            if (MaxHeight > 0)
                styles.Add($"max-height: {MaxHeight}px");

            return string.Join("; ", styles);
        }
    }

    public void Dispose()
    {
        AppStateService.IsMobileChanged -= StateHasChanged;
        _scrollTimer?.Stop();
        _scrollTimer?.Dispose();
        _dotNetHelper?.Dispose();
    }

    public enum PaginationType
    {
        NONE,
        DOTS,
        CUSTOM
    }
}
