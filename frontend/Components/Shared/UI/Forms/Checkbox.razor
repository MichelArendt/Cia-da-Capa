<div class="checkbox-container" @onclick="ToggleCheckbox" @onclick:stopPropagation>
    <InputCheckbox id="@Id"
                   @bind-Value="BindValue"
                   disabled="@Disabled" />
    <span class="checkmark">
        <Svg Path="@Svg.Paths.Check"  />
    </span>
    <label for="@Id">
        @Label
    </label>
</div>

@code {
    [Parameter] public required bool BindValue { get; set; }
    [Parameter] public string Id { get; set; } = Guid.NewGuid().ToString();
    [Parameter] public string Label { get; set; } = string.Empty;
    [Parameter] public bool Disabled { get; set; } = false;
    
    private void ToggleCheckbox()
    {
        BindValue = !BindValue;
        StateHasChanged();
    }
}