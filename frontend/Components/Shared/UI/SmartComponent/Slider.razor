 @inherits SmartComponentBase

@using frontend.Services

<div class="slider">
    <button class="slider__button @HeaderClassName" @onclick="Open">
        @HeaderContent
    </button>

    <div class="slider__content fullscreen-overlay slider__content--@Direction @(IsOpen ? "slider__content--visible" : "")">
        <div class="slider__content-wrapper" @onclick:stopPropagation>
            <button class="overlay__button overlay__button--close" @onclick="Close" @onclick:stopPropagation>
                <Svg Path="@Svg.Paths.Close" Width="20" Height="20" />
            </button>

            @BodyMobileContentTitle
            @BodyContent
        </div>
    </div>
</div>

@code {
    [Parameter]
    public RenderFragment? HeaderContent { get; set; } // Holds the first child

    [Parameter]
    public string? HeaderClassName { get; set; }

    [Parameter]
    public RenderFragment? BodyMobileContentTitle { get; set; }

    [Parameter]
    public RenderFragment? BodyContent { get; set; } // Holds the remaining children

    [Parameter]
    public SlideFromDirection Direction { get; set; } = SlideFromDirection.left;
    public enum SlideFromDirection
    {
        left,
        right,
        top,
        bottom
    }

    private string GetBodyClassName()
    {
        var baseClass = $"slider__content slider__content--{Direction}";
        if (IsOpen)
        {
            baseClass += " slider__content--visible";
        }
        return baseClass;
    }
}