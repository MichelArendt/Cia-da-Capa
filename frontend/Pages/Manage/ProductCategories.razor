    private async Task HandleValidSubmit()
    {
        IsSubmitting = true;
        errorMessage = null;

        var dto = new NewProductCategoryDto
        {
                Name = newProductModel.Name,
                Reference = newProductModel.Reference,
                IsActive = newProductModel.IsActive,
        };

        var response = await ProductCategoryService.CreateNewProductCategoryAsync(dto);

        // Console.WriteLine(response);
        // Console.WriteLine(await response.Content.ReadAsStringAsync());
        if (response.IsSuccessStatusCode)
        {
            Console.WriteLine(1);
            // Reset form fields
            newProductModel = new NewProductModel();

            // Re-fetch categories to update the list
            productCategories = (await ProductCategoryService.GetProductCategoriesAsync()).OrderBy(c => c.Name).ToList();

            // Re-render UI (forces Blazor to recognize the changes)
            StateHasChanged();
        }
        else
        {
            Console.WriteLine(2);
            errorMessage = $"Erro ao adicionar categoria: {await response.Content.ReadAsStringAsync()}";
            StateHasChanged();
        }

        IsSubmitting = false;
    }

    private void HandleInvalidSubmit()
    {
        errorMessage = "Por favor corrija os erros abaixo.";
    }

    public class NewProductModel
    {
        [Required(ErrorMessage = "Nome é obrigatório.")]
        public string Name { get; set; } = string.Empty;

        [Required(ErrorMessage = "Referência é obrigatória")]
        public string Reference { get; set; } = string.Empty;

        public bool IsActive { get; set; } = true;
    }
  
    private void SortCategoriesBy(ProductCategoryDto.SortBy.SortField sortField)
    {
        if (currentSortField.ColumnName == sortField.ColumnName)
        {
            isDescending = !isDescending; // Toggle order if clicking the same column
        }
        else
        {
            currentSortField = sortField;
            isDescending = false; // Default to ascending when switching columns
        }

        productCategories = isDescending
            ? productCategories.OrderByDescending(sortField.Selector).ToList()
            : productCategories.OrderBy(sortField.Selector).ToList();

        Console.WriteLine($"Sorting by: {currentSortField.ColumnName}, Order: {(isDescending ? "Descending" : "Ascending")}");
        StateHasChanged();
    }

    private async Task DeleteCategory(int categoryId)
    {
        var response = await ProductCategoryService.DeleteProductCategoryAsync(categoryId);

        if (response.IsSuccessStatusCode)
        {
            Console.WriteLine($"Category {categoryId} deleted successfully.");

            // Remove item manually
            productCategories = productCategories.Where(c => c.Id != categoryId).ToList();

            StateHasChanged(); // Re-render UI
        }
        else
        {
            var errorMessage = await response.Content.ReadAsStringAsync();
            Console.WriteLine($"Failed to delete category {categoryId}: {errorMessage}");
        }
    }
}