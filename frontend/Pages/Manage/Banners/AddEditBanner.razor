@page "/manage/banners/adicionar"
@page "/manage/banners/editar/{id:int}"

@layout ManageLayout

@using frontend.DTOs
@using frontend.Services.API
@using frontend.Components.Shared.UI

@using frontend.Components.Shared.UI.Forms.Smart
@using frontend.Models.Manage.Forms
@using frontend.ViewModels.Forms.Validation

@inject NotificationService NotificationService
@inject BannerService BannerService
@inject NavigationManager Nav
@inject ProductStateService ProductStateService

<PageTitle>@(IsEditMode ? "Editar Banner" : "Adicionar Banner")</PageTitle>

<h3>@(IsEditMode ? "Editar Banner" : "Adicionar Banner")</h3>

@if (IsEditMode && fetchBannerApiHandler.IsExecuting())
{
    <ContentLoader DisplayMessage="Carregando informações do banner..." />
}
else if (!IsEditMode || (fetchBannerApiHandler.IsSuccess() && fetchBannerApiHandler.Content is not null))
{
    <SmartForm 
            TModel="BannerFormModel" 
            Model="FormModel"
            Validator="ValidateWithFluent"
            ValidateOnInitialize="@IsEditMode"
            OnContextAvailable="ctx => _smartFormCtx = ctx"
            OnValidationStateChanged="valid => _canSubmit = valid"
            CanSubmitEvaluator="CanSubmitEvaluator">
        <!-- Text field with live validation -->
        <TextInput For="@nameof(FormModel.Title)"
                   Label="Título"
                   Placeholder="Ex: Bolsa masculina"
                   IsRequired="true"
                   LiveValidation="true" />


        <div class="display--row--above-breakpoint">
            <!-- Input field with live validation -->
            <NumberInput For="@nameof(FormModel.Priority)"
                         Label="Prioridade"
                         Placeholder="Ex: 0 (mais alto)"
                         Step="1"
                         Min="0"
                         IsRequired="true"
                         LiveValidation="true" />

            <AutocompleteSelect TItem="ProductLookupViewModel"
                                For="@nameof(FormModel.ProductId)"
                                Label="Produto"
                                Items="ProductStateService.ProductsListOrderedByReference"
                                SearchProperty="SearchString"
                                SelectedProperty="FullReference"
                                SelectedValueProperty="Id"
                                IsRequired="true"
                                LiveValidation="true"
                                ContainerClass="form-group">
                <ItemTemplate Context="p">
                    <div>
                        <strong>@p.FullReference</strong><br />
                        <span class="text-muted">@p.Title</span>
                    </div>
                </ItemTemplate>
            </AutocompleteSelect>
        </div>

        <FileInput 
            For="FormModel.FileMobile" 
            Label="Selecione uma imagem para o banner Mobile (640x360)" 
            IsRequired="!IsEditMode"
            CurrentImagePath="@FormModel.ImagePathMobile"
            LiveValidation="true" />

        <FileInput 
            For="FormModel.FileTablet" 
            Label="Selecione uma imagem para o banner Tablet (1024x512)"
            IsRequired="!IsEditMode"
            CurrentImagePath="@FormModel.ImagePathTablet" />

        <FileInput 
            For="FormModel.FileDesktop" 
            Label="Selecione uma imagem para o banner Desktop (1920x600)"
            IsRequired="!IsEditMode"
            CurrentImagePath="@FormModel.ImagePathDesktop" />

        <button type="button" class="btn btn-primary" disabled="@(!_canSubmit)" title="@SubmitTooltip" @onclick="SubmitForm">
            @(IsEditMode ? "Salvar Alterações" : "Criar Banner")
        </button>
    </SmartForm>
}
else
{
    <p>Erro ao carregar informações do banner.</p>
}

@code {
    [Parameter] public int? Id { get; set; }

    // The model instance we are editing
    private BannerFormModel FormModel = new();

    // Your validator instance (uses FluentValidation)
    private BannerFormModelValidator Validator = new(new List<ProductLookupViewModel>(), isEditMode: false);

    // This wraps FluentValidation logic for SmartForm usage
    private async Task<Dictionary<string, string>> ValidateWithFluent(BannerFormModel model)
    {
        var result = await Validator.ValidateAsync(model);
        // Converts FluentValidation results to Dictionary<string, string>
        return result.Errors
            .GroupBy(e => e.PropertyName)
            .ToDictionary(g => g.Key, g => g.First().ErrorMessage);
    }


    private bool IsEditMode => Id.HasValue;
    private ApiStateHandler<BannerDto> fetchBannerApiHandler = new();

    // Receives the SmartForm context for validation and state management
    private SmartFormContext? _smartFormCtx;

    private IEnumerable<string> RequiredFields => IsEditMode
    ? BannerFormModel.RequiredFieldsEdit
    : BannerFormModel.RequiredFieldsCreate;

    // private Dictionary<string, string> FieldErrors = new();
    // private HashSet<string> TouchedFields = new();

    protected override async Task OnInitializedAsync()
    {
        if (IsEditMode && Id.HasValue)
        {
            fetchBannerApiHandler = new(BannerService.GetByIdFunc(Id.Value));
            fetchBannerApiHandler.StateHasChanged += () => NotificationService.HandleApiStateChanged(fetchBannerApiHandler);
            await fetchBannerApiHandler.ExecuteAsync();

            BannerDto? banner = fetchBannerApiHandler.Content;

            if (banner != null)
            {
                FormModel = new BannerFormModel
                {
                    Title = banner.Title,
                    Priority = banner.Priority,
                    ProductId = banner.ProductId,
                    ImagePathMobile = banner.File_Path_Mobile,
                    ImagePathTablet = banner.File_Path_Tablet,
                    ImagePathDesktop = banner.File_Path_Desktop,
                };
            }
        }

        Validator = new BannerFormModelValidator(ProductStateService.ProductsListOrderedByReference, IsEditMode);
    }

    private bool _canSubmit = false;
    private string SubmitTooltip => _canSubmit ? "" : "Corrija os erros antes de submeter.";

    private bool CanSubmitEvaluator(SmartFormContext ctx)
    {
        // your existing submission logic, simplified
        return !ctx.FieldErrors.Any() &&
               RequiredFields.All(f => ctx.TouchedFields.Contains(f)) &&
               RequiredFields.All(f =>
               {
                   var val = typeof(BannerFormModel).GetProperty(f)?.GetValue(ctx.Model);
                   if (val is string s) return !string.IsNullOrWhiteSpace(s);
                   return val != null;
               });
    }

    private async Task SubmitForm()
    {
        if (!_canSubmit)
            return;

        if (IsEditMode && Id.HasValue)
        {
            await BannerService.UpdateAsync(Id.Value, FormModel);

            // Only redirect on success
            if (BannerService.UpdateBanner.IsSuccess())
            {
                NotificationService.DisplaySuccess("Atualizado com sucesso.");
                Nav.NavigateTo("manage/banners");
            } else
            {
                NotificationService.Display(BannerService.UpdateBanner.GetErrorNotificationModel("Erro ao atualizar o banner. Verifique os dados e tente novamente."));
            }
        }
        else
        {
            await BannerService.CreateAsync(FormModel);

            // Only redirect on success
            if (BannerService.CreateBanner.IsSuccess())
            {
                NotificationService.DisplaySuccess("Criado com sucesso.");
                Nav.NavigateTo("manage/banners");
            } else
            {
                NotificationService.Display(BannerService.CreateBanner.GetErrorNotificationModel("Erro ao criar o banner. Verifique os dados e tente novamente."));
            }
        }
    }
}
