        Data="productCategories"
        DisplayColumns="@(new Expression<Func<ProductCategoryDto, object>>[]{ c => c.IsActive, c => c.Name, c => c.Reference})"
        CustomRenderers="CustomColumnRenderers"  /> *@

@code {
    private List<ProductSizeLabelDto> productSizeLabels = new();
    private NewProductSizeLabelDto newProductSizeLabelModel = new();
    private string? errorMessage;
    private bool IsSubmitting { get; set; } = false;

    protected override void OnInitialized()
    {
        base.OnInitialized();

        AppState.Product.SizeLabels.StateChanged += StateHasChanged;
        SyncProductSizeLabels();
    }

    public void Dispose()
    {
        AppState.Product.SizeLabels.StateChanged -= StateHasChanged;
    }

    private void SyncProductSizeLabels()
    {
        productSizeLabels = AppState.Product.SizeLabels.Items;
        StateHasChanged();
    }

    protected override async Task OnInitializedAsync()
    {
        // productCategories = (await ProductCategoryService.GetProductCategoriesAsync()).ToList();
        // productCategories = (await ProductCategoryService.GetProductCategoriesAsync()).Cast<ISortableDto>().ToList();
    }

    private async Task HandleValidSubmit()
    {
        IsSubmitting = true;
        errorMessage = null;

        var dto = new NewProductSizeLabelDto
        {
                Name = newProductSizeLabelModel.Name,
                Label = newProductSizeLabelModel.Label,
        };

        var response = await ProductSizeLabelService.CreateNewProductSizeLabelAsync(dto);

        // Console.WriteLine(response);
        // Console.WriteLine(await response.Content.ReadAsStringAsync());
        if (response.IsSuccessStatusCode)
        {
            Console.WriteLine(1);
            // Reset form fields
            newProductSizeLabelModel = new NewProductSizeLabelDto();

            // Re-fetch categories to update the list
            await AppState.Product.SizeLabels.FetchItems();
            // AppState.CategoriesList = (await ProductCategoryService.GetProductCategoriesAsync()).OrderBy(c => c.Name).ToList();

            // Re-render UI (forces Blazor to recognize the changes)
            // StateHasChanged();
        }
        else
        {
            Console.WriteLine(2);
            errorMessage = $"Erro ao adicionar etiqueta: {await response.Content.ReadAsStringAsync()}";
            StateHasChanged();
        }

        IsSubmitting = false;
    }

    private void HandleInvalidSubmit()
    {
        errorMessage = "Por favor corrija os erros abaixo.";
    }

    public class NewProductSizeLabelsModel
    {
        [Required(ErrorMessage = "Nome é obrigatório.")]
        public string Name { get; set; } = string.Empty;

        [Required(ErrorMessage = "Etiqueta é obrigatória")]
        public string Label { get; set; } = string.Empty;
    }

    private async Task DeleteSizeLabel(int sizeLabeId)
    {
        var response = await ProductSizeLabelService.DeleteProductSizeLabelAsync(sizeLabeId);

        if (response.IsSuccessStatusCode)
        {
            Console.WriteLine($"Size label {sizeLabeId} deleted successfully.");

            // Remove item manually
            productSizeLabels = productSizeLabels.Where(c => c.Id != sizeLabeId).ToList();

            StateHasChanged(); // Re-render UI
        }
        else
        {
            var errorMessage = await response.Content.ReadAsStringAsync();
            Console.WriteLine($"Failed to delete size label {sizeLabeId}: {errorMessage}");
        }
    }
}