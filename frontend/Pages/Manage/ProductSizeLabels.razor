@page "/manage/rotulos"
@layout ManageLayout

@using System.Linq.Expressions
@using System.ComponentModel.DataAnnotations;
@using frontend.DTOs
@using frontend.DTOs.Contracts
@using frontend.Services
@using frontend.Services.API
@using frontend.Components.Shared.UI.SmartComponent
@using frontend.Components.Shared.UI.SVG

@inject AppStateService AppState
@inject ProductSizeLabelService ProductSizeLabelService

<PageTitle>Etiquetas de Tamanho (Gerenciamento)</PageTitle>

<h2>Adicionar nova etiqueta de tamanho de produto</h2>

<EditForm Model="@newProductSizeLabelModel" OnValidSubmit="HandleValidSubmit" OnInvalidSubmit="HandleInvalidSubmit">
    <DataAnnotationsValidator />
    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="feedback feedback--error">@errorMessage</div>
    }
    <ValidationSummary />

    <div>
        <label for="name">
            Nome (Pequeno, Médio, Grande etc):
        </label>

        <InputText name="name"
        id="name"
        autocomplete="on"
        placeholder="Pequeno"
        @bind-Value="newProductSizeLabelModel.Name"
        disabled="@IsSubmitting" />
        <ValidationMessage For="@(() => newProductSizeLabelModel.Name)" />
    </div>

    <div>
        <label for="label">
            Etiqueta (P, M, G, etc):
        </label>

        <InputText name="label"
        id="label"
        autocomplete="on"
        placeholder="P"
        @bind-Value="newProductSizeLabelModel.Label"
        disabled="@IsSubmitting" />
        <ValidationMessage For="@(() => newProductSizeLabelModel.Label)" />
    </div>

    <div>
        <button type="submit" disabled="@IsSubmitting">Adicionar etiqueta</button>
    </div>
</EditForm>

<List>
    <HeaderContent>
        <h2>Etiquetas de Tamanho</h2>
    </HeaderContent>

    <BodyContent>
        @if (productSizeLabels.Count == 0)
        {
            <span>Não há etiquetas cadastradas.</span>
        }
        else
        {
            <Table>
                <Thead>
                    <Tr>
                        <Th>
                            Etiqueta
                            <Svg Width="15" Height="15" ClassName="table__sorting-arrow" Path="@Svg.Paths.ArrowDropDown" />
                        </Th>
                        <Th>
                            Nome
                        </Th>
                        <Th>Ações</Th>
                    </Tr>
                </Thead>



                <Tbody>
                    @foreach (ProductSizeLabelDto sizeLabel in productSizeLabels)
                    {
                        <Tr ClassName="table__item">
                            <Td>@sizeLabel.Label</Td>
                            <Td>@sizeLabel.Name</Td>
                            <Td>
                                <Svg ClassName="table__actions" Path="@Svg.Paths.Edit" Width="30" Height="30" />
                                <Svg ClassName="table__actions" Path="@Svg.Paths.Delete" Width="30" Height="30" OnClick="@(() => DeleteSizeLabel(sizeLabel.Id))" />
                            </Td>
                        </Tr>
                    }
                </Tbody>
            </Table>
        }
    </BodyContent>
</List>


