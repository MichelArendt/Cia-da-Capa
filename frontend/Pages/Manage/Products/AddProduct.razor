@page "/manage/produtos/adicionar"
@layout ManageLayout

@using System.ComponentModel.DataAnnotations
@using System.Text.Json
@using frontend.DTOs
@using frontend.Services
@using frontend.Services.API

@inject NavigationManager NavigationManager
@inject AppStateService AppState
@inject ProductStateService ProductStateService
@inject ProductCategoryService ProductCategoryService
@inject ProductService ProductService

<PageTitle>Adicionar Produto (Gerenciamento)</PageTitle>

@if (ProductStateService.CategoriesDict.Any())
{
    <ProductForm />
} else {
    <Feedback Type="Feedback.FeedbackType.error">
        <span>Você deve adicionar alguma categoria primeiro!</span>
    </Feedback>
}

