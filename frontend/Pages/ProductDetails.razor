@page "/produto/{id:int}"

@inject ProductService ProductService
@inject ProductStateService ProductStateService

@using frontend.Components
@using frontend.Components.Shared.UI.Carousel
@using frontend.Utils
@using frontend.ViewModels.TabbedNavigation

@if (fetchFullProductApiHandler.IsExecuting())
{
    <ContentLoader />
} else if (fetchFullProductApiHandler.IsSuccess() && fetchFullProductApiHandler.Content != null)
{
    var product = fetchFullProductApiHandler.Content;
    <div class="product-container">
        <Carousel 
            Pagination="Carousel.PaginationType.CUSTOM"
            Items="currentCarouselItems"
            MaxWidth="600"
            PaginationArrows />

        <div class="product-details">
            <div class="two--no-before">
                <h1>
                    @product.Title
                    <span>@ProductStateService.GetProductFullReference(product)</span>
                </h1>
            </div>

            <TabbedNavigation 
                Tabs="@variantTabs"
                DefaultClasses="false"
                OnTabChanged="@OnVariantTabChanged" />

            @if (product.Sizes != null && product.Sizes.Any())
            {
                <div class="product-details__sizes">
                    <h2>Tamanhos:</h2>

                    @{
                        if (product.Sizes.Count > 1)
                        {
                            <TabbedNavigation 
                                Tabs="@sizeTabs" 
                                DefaultClasses="false"
                                OnTabChanged="@OnSizeTabChanged" />
                        } else
                        {
                            @RenderProductSize( product.Sizes!.FirstOrDefault()! )
                        }
                    }
                </div>
            }

            <div class="product-details__add-to-cart">
                <AddToCart Product="fetchFullProductApiHandler.Content"
                           SelectedSize="selectedSizeDto"
                           SelectedVariant="selectedVariantDto"
                    />
            </div>

            <div class="product-details__share">
                 <ShareProduct 
                     ProductTitle="@product.Title"
                     />
            </div>
        </div>
    </div>
} else 
{
    <p>Erro ao carregar os detalhes do produto.</p>
}

@if (suggestionFilters != null && suggestionFilters.Count > 0)
{
    <ProductSuggestions FetchFunction="ProductService.GetFilteredProductsListFunc(suggestionFilters)">
        <Title>
            OUTRAS <strong>MOCHILAS</strong>
        </Title>
    </ProductSuggestions>
}

@code {
    [Parameter] public int id { get; set; }

    private ApiStateHandler<ProductDto> fetchFullProductApiHandler = new();

    private string ClassNameTabs => $"product-details__tabs--default";
    private string ClassNameButton => $"product-details__tab-button--default";
    private string ClassNameContent => $"product-details__tab-content--default";

    private List<TabViewModel> sizeTabs = new();
    private List<TabViewModel> variantTabs = new();

    private List<CarouselItem> mainCarouselItems = new();
    private List<CarouselItem> currentCarouselItems = new();
    private Dictionary<int, List<CarouselItem>> variantCarouselItems = new(); // key: variantId

    // private int selectedVariantId = 0;
    // private int selectedSizeId = 0;

    private ProductSizeDto? selectedSizeDto;
    private ProductVariantDto? selectedVariantDto;

    private IDictionary<string, object?>? suggestionFilters;

    protected override async Task OnInitializedAsync()
    {
        await fetchFullProductApiHandler.ExecuteAsync(ProductService.GetFullProductDetailsFunc(id));

        if (fetchFullProductApiHandler.IsSuccess() && fetchFullProductApiHandler.Content?.Images != null)
        {
            var product = fetchFullProductApiHandler.Content;

            // Main product images
            mainCarouselItems = BuildCarouselItems(product.Images ?? new List<ProductImageDto>());
            currentCarouselItems = mainCarouselItems;

            // Variants images
            if (product.Variants != null)
            {
                foreach (var variant in product.Variants)
                {
                    if (variant.Images != null)
                        variantCarouselItems[variant.Id] = BuildCarouselItems(variant.Images);
                }
            }

            // Variants images
            suggestionFilters = new Dictionary<string, object?>
            {
                ["category_id"] = product.CategoryId,
                ["exclude_id"] = product.Id,
                ["with_images"] = true
            };


            // Build tabs for "Normal" and variants
            variantTabs.Clear();
            variantTabs.Add(new TabViewModel
            {
                Title = "NORMAL",
                Content = @<text>
                    <div class="product-details__variant-description">
                        @HtmlFormatter.ConvertNewlinesToParagraphs(product.Description)
                    </div>
                </text>,
                Visible = true
            });

            if (product.Variants != null && product.Variants.Any())
            {
                foreach (var variant in product.Variants)
                {
                    variantTabs.Add(new TabViewModel
                    {
                        Title = variant.Title,
                        Content = @<text>
                            <div class="product-details__variant-description">
                                @HtmlFormatter.ConvertNewlinesToParagraphs(variant.Description)
                            </div>
                        </text>
    ,
                        Visible = false
                    });
                }
            }

            //selectedVariantId = product.Variants?.FirstOrDefault()?.Id ?? 0; // Default to first variant
            //selectedVariantDto = product.Variants?.FirstOrDefault(); // Default to first variant

            // Build tabs for sizes
            if (product.Sizes != null && product.Sizes.Count > 1)
            {
                sizeTabs = product.Sizes.Select(size =>
                    new TabViewModel
                    {
                        Title = ProductStateService.SizeLabelsDict[size.SizeLabelId].Label,
                        Content = (@RenderProductSize(size)),
                        Visible = false
                    }).ToList();
                sizeTabs[0].Visible = true;

                //selectedSizeId = product.Sizes.FirstOrDefault()?.Id ?? 0; // Default to first size
                selectedSizeDto = product.Sizes?.FirstOrDefault(); // Default to first size
            }
        }
    }

    private List<CarouselItem> BuildCarouselItems(IEnumerable<ProductImageDto> images)
    {
        return images.Select(image => new CarouselItem
        {
            Content = builder =>
            {
                builder.OpenElement(0, "img");
                builder.AddAttribute(1, "src", image.MediumFilePath);
                builder.AddAttribute(2, "alt", "Imagem do produto");
                builder.CloseElement();
            },
            PaginationContent = builder =>
            {
                builder.OpenElement(0, "img");
                builder.AddAttribute(1, "src", image.ThumbnailFilePath);
                builder.AddAttribute(2, "alt", "Miniatura");
                builder.AddAttribute(3, "class", "carousel-thumbnail");
                builder.CloseElement();
            }
        }).ToList();
    }

    private void OnVariantTabChanged(int tabIndex)
    {
        // tabIndex 0 = Normal (main product), >= 1 = variant (order matches variantTabs)
        if (tabIndex == 0)
        {
            currentCarouselItems = mainCarouselItems;
            selectedVariantDto = null; // Clear selected variant DTO
            // selectedVariantId = 0;
        }
        else if (fetchFullProductApiHandler.Content?.Variants != null)
        {
            var variant = fetchFullProductApiHandler.Content.Variants.ElementAtOrDefault(tabIndex - 1);

            if (variant != null && variantCarouselItems.TryGetValue(variant.Id, out var images))
            {
                currentCarouselItems = images;
                // selectedVariantId = variant.Id;
                selectedVariantDto = variant; // Update selected variant DTO

            }
            else
            {
                // clear if variant is invalid or images not found
                currentCarouselItems = new List<CarouselItem>();
                // selectedVariantId = 0;
            }
        }
        else
        {
            //Clear if for some reason Variants is null
            currentCarouselItems = new List<CarouselItem>();
            // selectedVariantId = 0;
        }

        StateHasChanged();
    }

    private void OnSizeTabChanged(int tabIndex)
    {
        // tabIndex 0 = first size, >= 1 = other sizes (order matches sizeTabs)
        if (fetchFullProductApiHandler.Content?.Sizes != null && fetchFullProductApiHandler.Content.Sizes.Count > 0)
        {
            selectedSizeDto = fetchFullProductApiHandler.Content.Sizes.ElementAtOrDefault(tabIndex);
            // selectedSizeId = fetchFullProductApiHandler.Content.Sizes.ElementAtOrDefault(tabIndex)?.Id ?? 0;
        }
        else
        {
            //selectedSizeId = 0; // Clear if Sizes is null or empty
        }
        StateHasChanged();
    }

    private RenderFragment RenderProductSize(ProductSizeDto productSizeDto) 
        =>  @<div class="product-details__size">
                <div>
                    Largura:<br />
                    Altura: <br />
                    Profundidade:
                </div>

                <div class="product-details__size-values">
                    @productSizeDto.Width cm<br />
                    @productSizeDto.Height cm<br />
                    @productSizeDto.Depth cm
                </div>
            </div>;
}
