<section class="splash">
    <div class="splash-item">
        <div class="splash-item-svg">
            <Svg Path="@Svg.Paths.Verified" Width="40" Height="40" />
        </div>
        <div class="splash-item-text">
            no mercado<br />
            <strong>HÁ @YearsSince1995 ANOS</strong>
        </div>
    </div>

    <div class="splash-separator"></div>

    <div class="splash-item">
        <div class="splash-item-svg">
            <Svg Path="@Svg.Paths.Palette" Width="40" Height="40" />
        </div>
        <div class="splash-item-text">
            produtos<br />
            <strong>PERSONALIZADOS</strong>
        </div>
    </div>

    <div class="splash-separator"></div>

    <div class="splash-item">
        <div class="splash-item-svg">
            <Svg Path="@Svg.Paths.Medal" Width="40" Height="40" />
        </div>
        <div class="splash-item-text">
            garantia<br />
            <strong>DE QUALIDADE</strong>
        </div>
    </div>

    <div class="splash-separator"></div>

    <div class="splash-item">
        <div class="splash-item-svg">
            <Svg Path="@Svg.Paths.DeliveryTruckSpeed" Width="40" Height="40" />
        </div>
        <div class="splash-item-text">
            entrega para<br />
            <strong>TODO O BRASIL</strong>
        </div>
    </div>
</section>

<section class="splash-clients">
    <div class="splash-clients-text">
        <div class="splash-item-text">
            principais<br />
            <strong>CLIENTES</strong>
        </div>
    </div>

    @if (fetchClientLogosApiHandler.IsExecuting())
    {
        <ContentLoader DisplayMessage="Carregando logomarcas dos clientes..." />
    } else if (clientLogos.Any())
    {
        <div class="splash-clients-logos">
            <Carousel 
                Pagination="Carousel.PaginationType.NONE"
                Items="clientLogos"
                AutoScroll
                MaxHeight="200"/>
        </div>
    }
</section>

<ProductSuggestions FetchFunction="ProductService.GetHighlightedProductsListFunc()">
    <Title>
        NOSSOS PRODUTOS <strong>MAIS PROCURADOS</strong>
    </Title>
</ProductSuggestions>

@code {
    private ApiStateHandler<List<string>> fetchClientLogosApiHandler = new();
    private ApiStateHandler<List<BannerDto>> fetchBannersApiHandler = new();
    private ApiStateHandler<List<ProductDto>> fetchHighlightedRandomizedProductsApiHandler = new();
    private List<CarouselItem> clientLogos = new();

    private List<CarouselItem> bannerCarouselItems = new();
    private List<BannerDto> banners = new();
    private List<ProductDto> productsHighlightedRandomized = new();

    private int YearsSince1995 => CalculateYearsSince(new DateTime(1995, 4, 1));

    protected override async Task OnInitializedAsync()
    {
        bannerCarouselItems.Clear();

        // Fetch banners from API
        await fetchBannersApiHandler.ExecuteAsync(BannerService.GetAllBannersFunc());
        banners = fetchBannersApiHandler.IsSuccess() && fetchBannersApiHandler.Content != null
            ? fetchBannersApiHandler.Content
            : new List<BannerDto>();

        if (banners.Any())
        {
            // Use real banners
            bannerCarouselItems = banners.Select(banner => new CarouselItem
            {
                Content = @<picture>
                    <img src="@banner.File_Path_Mobile" alt="@banner.Title" />
                    <source srcset="@banner.File_Path_Tablet" media="(min-width: 769px)" />
                    <source srcset="@banner.File_Path_Desktop" media="(min-width: 1201px)" />
                </picture>
            }).ToList();
        }
        else
        {
            // Fallback: Use all products with images as banners
            await fetchHighlightedRandomizedProductsApiHandler.ExecuteAsync(ProductService.GetRandomHighlightedProductsWithImagesFunc());
            productsHighlightedRandomized = fetchHighlightedRandomizedProductsApiHandler.IsSuccess() && fetchHighlightedRandomizedProductsApiHandler.Content != null
                ? fetchHighlightedRandomizedProductsApiHandler.Content
                : new List<ProductDto>();

            var validProducts = productsHighlightedRandomized
                .Where(p => p.Images?.Any() == true)
                .ToList();

            bannerCarouselItems = validProducts.Select(product =>
            {
                var img = product.Images.OrderBy(i => i.Priority).FirstOrDefault();
                return new CarouselItem
                {
                    Content = @<div class="banner">
                        <picture class="banner__bg">
                            <img src="/images/banners/banner-640x360.jpg" alt="@product.Title" />
                            <source srcset="/images/banners/banner-1024x512.jpg" media="(min-width: 769px)" />
                            <source srcset="/images/banners/banner-1920x600.jpg" media="(min-width: 1201px)" />
                        </picture>
                        <img class="banner__product" src="@img.MediumFilePath" alt="@product.Title" />
                    </div>
                };
            }).ToList();
        }





        // await fetchBannersApiHandler.ExecuteAsync(BannerService.GetAllBannersFunc());

        // if (fetchBannersApiHandler.IsSuccess() && fetchBannersApiHandler.Content != null)
        // {
        //     banners = fetchBannersApiHandler.Content;

        //     Check if there are no banners
        //     if (!banners.Any())
        //     {
        //         No banners found, we must then check for highlighted products to use on banner
        //         await fetchHighlightedRandomizedProductsApiHandler.ExecuteAsync(ProductService.GetRandomHighlightedProductsWithImagesFunc());

        //         if ( fetchHighlightedRandomizedProductsApiHandler.IsSuccess() )
        //         {
        //             productsHighlightedRandomized = fetchHighlightedRandomizedProductsApiHandler.Content ?? new List<ProductDto>();
        //         }
        //     }

        //     StateHasChanged();
        // }


        // Fetch client logos
        await fetchClientLogosApiHandler.ExecuteAsync(UtilsService.GetClientLogosFunc());

        if (fetchClientLogosApiHandler.IsSuccess() && fetchClientLogosApiHandler.Content != null)
        {
            clientLogos = fetchClientLogosApiHandler.Content.Select(imagePath =>
            {
                // Extract filename from path
                var fileName = System.IO.Path.GetFileNameWithoutExtension(imagePath);

                // Replace - and _ with spaces, then capitalize each word
                var altText = System.Globalization.CultureInfo.CurrentCulture.TextInfo
                    .ToTitleCase(fileName.Replace("-", " ").Replace("_", " "));

                return new CarouselItem
                {
                    Content = builder =>
                    {
                        builder.OpenElement(0, "img");
                        builder.AddAttribute(1, "src", imagePath);
                        builder.AddAttribute(2, "alt", altText);
                        builder.CloseElement();
                    }
                };
            }).ToList();

            StateHasChanged();
        }
    }

    private int CalculateYearsSince(DateTime startDate)
    {
        var today = DateTime.Today;
        int years = today.Year - startDate.Year;
        if (today < startDate.AddYears(years))
        {
            years--; // hasn't reached the anniversary this year yet
        }
        return years;
    }

    public class UnifiedBannerItem
    {
        public bool IsProductBanner { get; set; } // true for product-based, false for real banners
        public string MobilePath { get; set; } = string.Empty;
        public string TabletPath { get; set; } = string.Empty;
        public string DesktopPath { get; set; } = string.Empty;
        public string AltText { get; set; } = string.Empty;
        public string? ProductImagePath { get; set; } // null for real banners
    }
}
