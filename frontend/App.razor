@using frontend.Components.Shared.Utilities

@inject NavigationManager Navigation
@inject AppStateService AppState
@inject UserService UserService
@inject NotificationService NotificationService

@if (AppState.Product.Categories.IsFetching() || AppState.Product.SizeLabels.IsFetching())
{
    <!-- Show a loader if the essential data hasn't loaded yet -->
    <ContentLoader DisplayMessage="Carregando dados essenciais..." />
}
else if (AppState.Product.Categories.HasFailed() || AppState.Product.SizeLabels.HasFailed())
{
    <!-- If either fetch has failed, show a 500 page or custom error -->
    <PageTitle>500 - Cia da Capa</PageTitle>
    <_500 />
    @NotificationService.DisplayError(
                "Problema ao conectar com o bando de dados. Tente novamente mais tarde!",
                "Problema ao conectar com o bando de dados.")
    ;
}
else if (AppState.IsCheckingAuth)
{
    <ContentLoader DisplayMessage="Verificando sessão..." />
}
else
{
    <Router AppAssembly="@typeof(App).Assembly" OnNavigateAsync="HandleNavigationAsync">
        <Found Context="routeData">
            <RouteView RouteData="@routeData" DefaultLayout="@typeof(MainLayout)" />
            <FocusOnNavigate RouteData="@routeData" Selector="h1" />
        </Found>
        <NotFound>
            @{
                var uri = Navigation.Uri;
                if (uri.Contains("/manage/"))
                {
                    // Manually show "Manage" style content
                    <LayoutView Layout="@typeof(ManageLayout)">
                        <_404 PageTitle="404 (Gerenciamento)" />
                    </LayoutView>
                }
                else
                {
                    <LayoutView Layout="@typeof(MainLayout)">
                        <_404 PageTitle="404 - Cia da Capa" />
                    </LayoutView>
                }
            }
        </NotFound>
    </Router>

    <ResizeListener />
}

<Notification />

