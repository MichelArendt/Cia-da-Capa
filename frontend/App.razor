@* } *@

@code {
    // [Inject]
    // private NavigationManager Navigation { get; set; } = default!;

    // [Inject]
    // private AppStateService AppState { get; set; } = default!;

    protected override void OnInitialized()
    {
        // AppState.IsAuthenticatedChanged += StateHasChanged;
        AppState.IsMobileChanged += StateHasChanged;
        AppState.IsCheckingAuthChanged += StateHasChanged;
        AppState.IsAuthenticatedChanged += StateHasChanged;
        AppState.Product.Categories.StateChanged += StateHasChanged;
        AppState.Product.SizeLabels.StateChanged += StateHasChanged;
    }

    public void Dispose()
    {
        AppState.IsMobileChanged -= StateHasChanged;
        AppState.IsCheckingAuthChanged -= StateHasChanged;
        AppState.IsAuthenticatedChanged -= StateHasChanged;
        AppState.Product.Categories.StateChanged -= StateHasChanged;
        AppState.Product.SizeLabels.StateChanged -= StateHasChanged;
    }

    protected override async Task OnInitializedAsync()
    {
        await AppState.Product.Categories.FetchItems();
        await AppState.Product.SizeLabels.FetchItems();
    }

    protected override void OnAfterRender(bool firstRender) {
        if(firstRender){

        }
    }

    private async Task HandleNavigationAsync(NavigationContext context)
    {
        // If path starts with "manage" and user not going to manage/login,
        // but we do not know or suspect they are not authenticated:
        // e.g.: /manage/somepage requires user to be authenticated
        if (context.Path.StartsWith("manage", StringComparison.OrdinalIgnoreCase)
            && !context.Path.Contains("manage/login", StringComparison.OrdinalIgnoreCase))
        {
            // If user not known to be authenticated, do a server check
            if (!AppState.IsAuthenticated)
            {
                // Show the loader
                AppState.IsCheckingAuth = true;

                // Actually call the server
                var response = await UserService.ValidateSessionAsync();

                // Done checking
                AppState.IsCheckingAuth = false;

                // If not valid, push them to /manage/login
                if (!response)
                {
                    // Store the attempted path before redirect
                    AppState.AttemptedPath = context.Path;

                    AppState.IsAuthenticated = false;
                    Navigation.NavigateTo("manage/login");
                }
                else
                {
                    AppState.IsAuthenticated = true;
                    // Let them continue to the route
                }
            }
        }
    }
}