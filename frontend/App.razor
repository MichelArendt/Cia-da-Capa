@using frontend.Components.Shared.Utilities

@inject NavigationManager Navigation
@inject AppStateService AppStateService
@inject ProductStateService ProductStateService
@inject UserService UserService
@inject NotificationService NotificationService

@if (ProductStateService.CategoriesApiHandler.IsExecuting() || ProductStateService.SizeLabelsApiHandler.IsExecuting())
{
    <!-- Show a loader if the essential data hasn't loaded yet -->
    <ContentLoader DisplayMessage="Carregando dados essenciais..." />
}
else if (
    ProductStateService.CategoriesApiHandler.HasFailed || 
    ProductStateService.SizeLabelsApiHandler.HasFailed @* ||
    !ProductStateService.Categories.Any() || 
    !ProductStateService.SizeLabels.Any() *@
)
{
    <!-- If either fetch has failed, show a 500 page or custom error -->
    <PageTitle>500 - Cia da Capa</PageTitle>
    <_500 />
    string errorMessage = ProductStateService.CategoriesApiHandler.ErrorMessage ?? "";
    errorMessage += ProductStateService.SizeLabelsApiHandler.ErrorMessage ?? "";

    @NotificationService.DisplayError(
                                                                                                "Problema ao conectar com o bando de dados. Tente novamente mais tarde!",
                                                                                                errorMessage
                                                                                            );
}
else if (AppStateService.IsCheckingAuth)
{
    <ContentLoader DisplayMessage="Verificando sessão..." />
}
else
{
    <Router AppAssembly="@typeof(App).Assembly" OnNavigateAsync="HandleNavigationAsync">
        <Found Context="routeData">
            <RouteView RouteData="@routeData" DefaultLayout="@typeof(MainLayout)" />
            <FocusOnNavigate RouteData="@routeData" Selector="h1" />
        </Found>
        <NotFound>
            @{
                var uri = Navigation.Uri;
                if (uri.Contains("/manage/"))
                {
                    // Manually show "Manage" style content
                    <LayoutView Layout="@typeof(ManageLayout)">
                        <_404 PageTitle="404 (Gerenciamento)" />
                    </LayoutView>
                }
                else
                {
                    <LayoutView Layout="@typeof(MainLayout)">
                        <_404 PageTitle="404 - Cia da Capa" />
                    </LayoutView>
                }
            }
        </NotFound>
    </Router>

    <ResizeListener />
}

<Notification />

@code {
    private ApiStateHandler<object> validateSessionApiHandler = new();
    private bool _authCheckInProgress = false;

    protected override void OnInitialized()
    {
        validateSessionApiHandler = new(UserService.ValidateSessionFunc());

        AppStateService.IsMobileChanged += StateHasChanged;
        AppStateService.IsCheckingAuthChanged += StateHasChanged;
        AppStateService.IsAuthenticatedChanged += StateHasChanged;

        ProductStateService.CategoriesApiHandler.StateHasChanged += StateHasChanged;
        ProductStateService.SizeLabelsApiHandler.StateHasChanged += StateHasChanged;
        ProductStateService.CategoriesChanged += StateHasChanged;
        ProductStateService.SizeLabelsChanged += StateHasChanged;
    }

    public void Dispose()
    {
        AppStateService.IsMobileChanged -= StateHasChanged;
        AppStateService.IsCheckingAuthChanged -= StateHasChanged;
        AppStateService.IsAuthenticatedChanged -= StateHasChanged;

        ProductStateService.CategoriesApiHandler.StateHasChanged -= StateHasChanged;
        ProductStateService.SizeLabelsApiHandler.StateHasChanged -= StateHasChanged;
        ProductStateService.CategoriesChanged -= StateHasChanged;
        ProductStateService.SizeLabelsChanged -= StateHasChanged;
    }

    protected override async Task OnInitializedAsync()
    {
        // Initial fetch of categories and sizelabels
        await Task.WhenAll(
            ProductStateService.CategoriesApiHandler.ExecuteAsync(),
            ProductStateService.SizeLabelsApiHandler.ExecuteAsync()
        );
    }

    private async Task HandleNavigationAsync(NavigationContext context)
    {
        AppStateService.TriggerNavigationChanged();

        // If we are already checking auth, skip
        if (_authCheckInProgress || AppStateService.IsCheckingAuth)
            return;

        // This local flag ensures no second re-entry
        _authCheckInProgress = true;

        try
        {
            // check if the user is under manage route
            if (context.Path.StartsWith("manage", StringComparison.OrdinalIgnoreCase))
            {
                // Check if going to login
                bool goingToLogin = context.Path.Contains("manage/login", StringComparison.OrdinalIgnoreCase);

                // If we are *not* going to /manage/login, we want to see if the user is authenticated
                // or if the user might have an expired session.
                // Show loader and call the server, unless we already know they're authenticated.
                if (!goingToLogin || !AppStateService.IsAuthenticated)
                {
                    AppStateService.IsCheckingAuth = true;
                    StateHasChanged();

                    await validateSessionApiHandler.ExecuteAsync();
                    if (validateSessionApiHandler.IsSuccess())
                    {
                        AppStateService.IsAuthenticated = true;
                    }
                    else
                    {
                        AppStateService.IsAuthenticated = false; // Just to be explicit
                    }
                }

                // If user is not authenticated after that, but also not going to login, redirect them
                if (!AppStateService.IsAuthenticated)
                {
                    if (!goingToLogin)
                    {
                        // Store the attempted path
                        AppStateService.AttemptedPath = context.Path;
                        Navigation.NavigateTo("manage/login");
                    }
                }
                else
                {
                    // The user is now authenticated:
                    // If they're heading to /manage/login, we can redirect them away
                    if (goingToLogin)
                    {
                        // If we have an AttemptedPath, go there; otherwise /manage
                        if (!string.IsNullOrEmpty(AppStateService.AttemptedPath))
                        {
                            Navigation.NavigateTo(AppStateService.AttemptedPath);
                        }
                        else
                        {
                            Navigation.NavigateTo("manage");
                        }
                    }
                }
            }
        }
        finally
        {
            // Done checking
            AppStateService.IsCheckingAuth = false;
            _authCheckInProgress = false;
        }
    }
}