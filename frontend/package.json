{
  "name": "frontend",
  "version": "1.0.0",
  "scripts": {
    "build-manage": "sass wwwroot/scss/manage.scss:../build/css/manage.css --no-source-map",

    "build-main": "sass wwwroot/scss/main.scss:../build/css/main.css --no-source-map",

    "build-shared": "sass wwwroot/scss/shared.scss:../build/css/shared.css --no-source-map",

    "build": "npm run build-manage && npm run build-main && npm run build-shared",

    "watch-scss": "sass --watch wwwroot/scss/manage.scss:../build/css/manage.css wwwroot/scss/main.scss:../build/css/main.css wwwroot/scss/shared.scss:../build/css/shared.css --no-source-map",

    "browser-sync": "browser-sync start --config bs-config.js",

    "watch": "concurrently \"npm run watch-scss\" \"npm run browser-sync\""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "devDependencies": {
    "concurrently": "^9.1.2",
    "sass": "^1.83.1"
  },
  "dependencies": {
    "browser-sync": "^3.0.3"
  }
}
