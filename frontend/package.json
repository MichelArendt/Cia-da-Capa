{
  "name": "frontend",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "build-manage": "sass wwwroot/scss/manage/manage.scss:wwwroot/css/manage/manage.css --no-source-map",
    "build-main": "sass wwwroot/scss/main.scss:wwwroot/css/main.css --no-source-map",
    "build": "npm run build-manage && npm run build-main",
    "watch-scss": "sass --watch wwwroot/scss/manage/manage.scss:wwwroot/css/manage/manage.css wwwroot/scss/main.scss:wwwroot/css/main.css --no-source-map",
    "browser-sync": "browser-sync start --proxy http://localhost:5038 --serveStatic --port 3000 --files 'wwwroot/css/**/*.css' --no-open --no-notify",
    "watch": "concurrently \"npm run watch-scss\" \"npm run browser-sync\""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "devDependencies": {
    "concurrently": "^9.1.2",
    "sass": "^1.83.1"
  },
  "dependencies": {
    "browser-sync": "^3.0.3"
  }
}
