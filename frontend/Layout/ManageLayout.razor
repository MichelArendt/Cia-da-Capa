@code {
    private ApiStateHandler<object> logoutApiHandler = new();

    protected override void OnInitialized()
    {
        base.OnInitialized();

        AppStateService.IsManageRoute = true;
    }

    public void Dispose()
    {
    }

    private async Task UserLogout()
    {
        if (AppStateService.IsAuthenticated)
        {
            await logoutApiHandler.ExecuteAsync(UserService.LogoutFunc());

            if (logoutApiHandler.IsSuccess())
            {
                AppStateService.IsAuthenticated = false;
                Navigation.NavigateTo("manage/login");
            } else {
                NotificationService.Display(logoutApiHandler.GetErrorNotificationModel("Erro ao tentar deslogar."));
            }
        }
    }
}

